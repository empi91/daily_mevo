# App settings
MEVO_ENVIRONMENT=development
MEVO_APP_VERSION=0.1.0

# Supabase (not needed for initial deploy)
# MEVO_DATABASE_URL=postgresql+asyncpg://user:pass@host:6543/dbname
# MEVO_SUPABASE_URL=https://your-project.supabase.co
# MEVO_SUPABASE_ANON_KEY=your-anon-key

# Auth
MEVO_JWT_SECRET=change-me-in-production  # must be a strong random string in production

# Collector settings
MEVO_COLLECTOR_ENABLED=true
MEVO_COLLECTOR_INTERVAL_SECONDS=300

# Retention & DB monitoring
# MEVO_SNAPSHOT_RETENTION_DAYS=5          # delete snapshots older than N days (default: 5)
MEVO_NTFY_TOPIC=your-ntfy-topic           # REQUIRED for alerts — subscribe to this topic in the ntfy app
# MEVO_DB_SIZE_WARNING_MB=360             # warning alert threshold (default: 360)
# MEVO_DB_SIZE_CRITICAL_MB=410            # critical alert threshold (default: 410)
# MEVO_DB_MONITOR_INTERVAL_HOURS=6        # how often to check DB size (default: 6)

# Observability
# LOGFIRE_TOKEN=your-logfire-token        # enables Pydantic Logfire tracing (omit to disable)
# MEVO_FRESHNESS_THRESHOLD_SECONDS=3600   # max age (seconds) before data is considered stale
# MEVO_LOG_LEVEL=INFO                     # DEBUG, INFO, WARNING, ERROR

# CORS (production: include all domains that serve the frontend)
# MEVO_CORS_ORIGINS=["https://srv66-20312.wykr.es","https://dailymevo.pl","https://www.dailymevo.pl"]

# Mikr.us (for deploy script, not consumed by the app)
# MIKRUS_SERVER=srvXX
# MIKRUS_SSH_PORT=10XXX
# MIKRUS_APP_PORT=20XXX
# MIKRUS_API_KEY=your-api-key
